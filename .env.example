# === API 키 설정 ===
# 이 파일을 .env 로 복사한 뒤 실제 키 값으로 채우세요:
#   cp .env.example .env

# OpenAI API 키 — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API 키 — https://aistudio.google.com/apikey
# google-genai SDK 는 GOOGLE_API_KEY 또는 GEMINI_API_KEY 를 읽습니다.
GOOGLE_API_KEY=your_gemini_api_key_here

# === 모델 ID (핵심 테스트 세트; design/research_models_api.md 참고) ===
# 다른 모델로 바꾸려면 값만 교체하세요. 미설정 시 스크립트의 기본값이 사용됩니다.
OPENAI_IMAGE_MODEL=gpt-image-2
GEMINI_PRO_IMAGE_MODEL=gemini-3-pro-image
GEMINI_FLASH_IMAGE_MODEL=gemini-3.1-flash-image
